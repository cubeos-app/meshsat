# MeshSat Hub — Production Environment
# Copy this file to .env and edit for your deployment.

# ── Required ───────────────────────────────────────────────────
# Public domain name pointing to this server (for TLS).
DOMAIN=hub.example.com

# ── MeshSat ────────────────────────────────────────────────────
MESHSAT_TAG=latest
MESHSAT_RETENTION_DAYS=90
MESHSAT_BACKUP_INTERVAL_HOURS=12
MESHSAT_BACKUP_MAX_KEEP=14
MESHSAT_PAID_RATE_LIMIT=60
MESHSAT_ANNOUNCE_INTERVAL=300

# ── Optional: APRS-IS IGate ───────────────────────────────────
# HUB_APRSIS_ENABLED=true
# HUB_APRSIS_CALLSIGN=YOURCALL
# HUB_APRSIS_PASSCODE=12345
# HUB_APRSIS_SERVER=euro.aprs2.net:14580
