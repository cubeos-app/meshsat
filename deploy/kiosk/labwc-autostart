# labwc autostart — runs once labwc is ready.
# [MESHSAT-578 / kiosk session]
#
# Template variables substituted by scripts/install-kiosk.sh:
#   __BRIDGE_URL__  → the kiosk URL
#
# Output rotation via wlr-randr (labwc rc.xml 0.7 has no rotate
# element; wlr-randr uses wlr_output_management_v1 which labwc
# implements).

# 1. Output rotation — DSI-2 90° CW (native portrait → landscape).
wlr-randr --output DSI-2 --transform 90 &

# 2. Wait for the bridge container to be healthy before launching
#    Chromium. Otherwise the browser boots faster than docker and
#    shows "site can't be reached" until the next manual reload.
#    Poll the bridge's /health endpoint every second; bail out after
#    5 minutes with a soft launch (Chromium will just retry) so the
#    screen isn't black forever in a genuinely broken deploy.
BRIDGE_HEALTH_URL="http://localhost:6050/health"
BRIDGE_WAIT_MAX=300   # 5 minutes

i=0
while [ "$i" -lt "$BRIDGE_WAIT_MAX" ]; do
  if curl -fsS --max-time 2 "$BRIDGE_HEALTH_URL" >/dev/null 2>&1; then
    break
  fi
  sleep 1
  i=$((i + 1))
done

# 3. Idle backlight dim — swayidle hooks labwc's idle notifier and
#    dims the panel to 32/255 after 10 min of no input, restores to
#    200/255 on activity. The backlight write is delegated to a
#    sudoers-scoped wrapper (/usr/local/bin/meshsat-backlight),
#    installed with a one-command sudoers entry so the kiosk user
#    can't reach anything else under /sys. [MESHSAT-580]
swayidle -w \
  timeout 600 'sudo -n /usr/local/bin/meshsat-backlight 32' \
  resume 'sudo -n /usr/local/bin/meshsat-backlight 200' &

# 4. Chromium kiosk — policy lockdown in
#    /etc/chromium/policies/managed/meshsat-kiosk.json.
#    --force-device-scale-factor=1.5 scales CSS pixels to make the
#    UI readable on the 7" DSI panel (1280×720 native → 853×480
#    logical).  --enable-use-zoom-for-dsf=true is required alongside
#    it so Chromium implements the scale via CSS zoom rather than
#    direct viewport scaling — otherwise touch coordinates stay
#    unscaled and every tap lands in the wrong spot. Verified live
#    on tesseract 2026-04-19. [MESHSAT-549/578]
# Long-running kiosk resilience flags [MESHSAT-628]:
# Chromium's default backgrounding heuristics throttle setInterval
# handlers + lazy-GC even in foreground kiosk mode after long
# uptimes — observed on tesseract 2026-04-20 as "info out of date
# + clicks don't register" after 10 h (scroll still worked because
# it's GPU-composited, independent of the main JS thread). These
# flags plus a bounded V8 heap make polling + click dispatch
# latency deterministic over multi-day uptimes.
chromium-browser \
  --kiosk \
  --noerrdialogs \
  --disable-infobars \
  --disable-translate \
  --no-first-run \
  --no-default-browser-check \
  --start-fullscreen \
  --touch-events=enabled \
  --force-device-scale-factor=1.5 \
  --enable-use-zoom-for-dsf=true \
  --disable-background-timer-throttling \
  --disable-renderer-backgrounding \
  --disable-backgrounding-occluded-windows \
  --disable-features=CalculateNativeWinOcclusion,BackForwardCache \
  --js-flags="--max-old-space-size=256" \
  --app="__BRIDGE_URL__" &
# NB: the URL MUST be quoted — it contains `&` (query-string
# separator between kiosk=1 and shell=operator). Without quotes,
# bash parses the unquoted `&` as job-control and drops everything
# after it, so Chromium would load only `?kiosk=1` and silently
# ignore the `shell=…` role param. Verified on tesseract
# 2026-04-19: bug dropped the role selector, bringing up the
# wrong nav surface. [MESHSAT-549]
