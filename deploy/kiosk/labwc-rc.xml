<?xml version="1.0"?>
<!--
  labwc kiosk config. Minimal — just tells the compositor not to
  render gaps, focus outlines, or a cursor around the single
  fullscreen Chromium client. Touch rotation handled by the udev
  rule (see 99-touch-rotate.rules); output rotation handled by
  the autostart wlr-randr call; cursor hidden at the compositor
  level below (CSS `cursor: none` only hides Chromium's cursor —
  the Wayland pointer rendered by labwc sits on top of that).
-->
<labwc_config>
  <core>
    <gap>0</gap>
    <cycleViewOutlines>no</cycleViewOutlines>
  </core>
  <theme>
    <!-- `blank` is a custom xcursor theme installed by
         install-blank-cursor.sh — every cursor variant symlinks to
         a 1×1 transparent PNG, so labwc draws *zero* visible
         pixels regardless of pointer activity. Beats cursorSize=1
         which was still faintly visible at Touch Display 2 DPI. -->
    <cursorTheme>blank</cursorTheme>
    <cursorSize>1</cursorSize>
  </theme>
</labwc_config>
