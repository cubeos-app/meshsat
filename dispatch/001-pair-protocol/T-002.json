  "requirements": [
    {
      "id": "REQ-004",
      "body": "The system shall store the PIN + pairing key + armed-at timestamp in the bridge database (touch-display-controlled lifecycle)."
    },
    {
      "id": "REQ-012",
      "body": "The system shall return `{cert: PEM, client_id: string, ca_chain: PEM, rns_announce: optional, hub_url: optional}` on successful claim."
    },
    {
      "id": "REQ-014",
      "body": "The system shall persist the new `paired_clients` row with `client_id`, `public_key`, `created_at`."
    },
    {
      "id": "REQ-016",
      "body": "The system shall issue JWTs with a 1-hour TTL (`pair.JWTTTL`)."
    },
    {
      "id": "REQ-017",
      "body": "When the client presents a JWT signed by its Ed25519 private key, the middleware shall verify against `paired_clients.public_key`."
    },
    {
      "id": "REQ-018",
      "body": "The system shall expose `POST /api/v2/pair/refresh` for clients to refresh JWTs before expiry."
    }
  ],
