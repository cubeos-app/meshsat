{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://meshsat.net/schemas/bridge/paired-client.json",
  "title": "PairedClient",
  "description": "Paired client row in the bridge's database (internal/pair/).",
  "type": "object",
  "required": ["client_id", "cert_sha256", "paired_at"],
  "additionalProperties": false,
  "properties": {
    "client_id": {"type": "string", "minLength": 1},
    "cert_sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "jwt_alias": {"type": ["string", "null"]},
    "paired_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "expires_at": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]+)?(Z|[+-][0-9]{2}:[0-9]{2})$"
    }
  }
}
